# Path to goose binary
GOOSE := "go run github.com/pressly/goose/v3/cmd/goose@v3.27.0"

# Database connection string
DATABASE_URL := "postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable"

# Migration directory
MIGRATION_DIR := "internal/adapters/outbound/postgres/migrations"

generate-oas:
	go run github.com/ogen-go/ogen/cmd/ogen@latest \
		--target internal/adapters/inbound/httpapi/gen \
		--clean internal/adapters/inbound/httpapi/openapi.yaml

generate-sqlc:
	go run github.com/sqlc-dev/sqlc/cmd/sqlc@latest generate

generate-mappers:
	go run github.com/jmattheis/goverter/cmd/goverter@latest gen github.com/faber-numeris/beholder/authn/internal/platform/mapper

migrate-all-up:
	{{GOOSE}} -dir {{MIGRATION_DIR}} postgres "{{DATABASE_URL}}" up

migrate-all-down:
	{{GOOSE}} -dir {{MIGRATION_DIR}} postgres "{{DATABASE_URL}}" down

# Build with the go.work workspace disabled, so dependencies resolve against
# go.mod/go.sum exactly as they would outside this machine (e.g. in CI).
build:
	GOWORK=off go build ./...

test:
	go test ./...

test-coverage:
	go test -coverprofile=coverage.out ./...
	go tool cover -func=coverage.out | tail -n 1
	@go tool cover -func=coverage.out | tail -n 1 | awk '{print $$3}' | sed 's/%//' | awk '{if ($$1 < 90) exit 1}'
